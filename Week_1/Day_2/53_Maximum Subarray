class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int sum = 0;
        int newSum = nums[0];

        for(int num : nums) {
            sum += num;

            newSum = max(newSum, sum);

            if(sum < 0) {
                sum = 0;
            }
        }
        return newSum;
    }
};
